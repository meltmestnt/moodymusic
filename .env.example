# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Must match the host:port you actually open in the browser. Spotify rejects
# 'localhost' for new apps — use 127.0.0.1.
NEXTAUTH_URL=http://127.0.0.1:3001

# Spotify — create app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:3001/api/auth/callback/spotify as a Redirect URI.
# (Match the host AND port to your NEXTAUTH_URL exactly.)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4o-mini — cheapest with
# strong music knowledge for ~$0.0003 per mood search).
# OPENAI_MODEL=gpt-4o-mini

# MongoDB — used to log mood searches, plays, and favorite events. The app
# works without this (persistence simply skips), so leave blank for a
# storage-less setup. The repo ships a `docker-compose.yml` you can boot
# with `npm run db:up`; that exposes Mongo on the URI below.
# For Atlas instead:
#   mongodb+srv://<user>:<pass>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=moodymusic

# Redis — used to cache mood-search results for 15 minutes so we don't
# re-bill OpenAI for the same prompt. Leave blank to disable caching;
# the route works without it. The bundled docker stack (`npm run db:up`)
# starts Redis on this URL automatically.
REDIS_URL=redis://localhost:6379

# Telegram bot — only needed if you run `npm run bot`. Create a bot with
# @BotFather (https://t.me/BotFather) to get a token; in BotFather also
# run `/setdomain` and `/newapp` with the same HTTPS URL below so the
# Mini App opens cleanly. Telegram REJECTS http:// Mini App URLs, so for
# local dev expose the dev server through a tunnel (ngrok, cloudflared)
# and put the HTTPS URL here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=https://moodymusic.app
# Public bot username (without the leading @). Used by the web app to
# build deep links like https://t.me/<username> for the
# "Connect to Telegram" surfaces. If unset the connect buttons render
# as disabled placeholders.
TELEGRAM_BOT_USERNAME=moodymusic_music_bot
# Shared secret the bot sends to the web app when exchanging account-link
# tokens. Generate with: openssl rand -hex 32. Both the bot and the web
# server need the same value. If unset, the linking flow is disabled and
# the bot only works as a Mini App launcher.
TELEGRAM_BOT_API_SECRET=96281619085013971965759969085197
# Optional: where the bot can reach the moodymusic web API. Defaults to
# TELEGRAM_WEBAPP_URL above (same origin as the Mini App). Override only
# for split deployments where the bot runs separately from the web server.
# MOODYMUSIC_API_URL=https://moodymusic.app
