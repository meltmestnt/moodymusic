{
  "name": "moodymusic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v",
    "db:logs": "docker compose logs -f mongo",
    "db:shell": "docker compose exec mongo mongosh moodymusic",
    "redis:logs": "docker compose logs -f redis",
    "redis:cli": "docker compose exec redis redis-cli",
    "redis:flush": "docker compose exec redis redis-cli FLUSHDB",
    "bot": "tsx bot/index.ts",
    "bot:dev": "tsx watch bot/index.ts"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.1.6",
    "@tanstack/react-query": "^5.62.7",
    "ioredis": "^5.10.1",
    "mongodb": "^7.2.0",
    "next": "^15.1.0",
    "next-auth": "^4.24.11",
    "openai": "^4.76.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
